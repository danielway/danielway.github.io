---
layout: base.njk
tags: projects

createdDate: git Created
updatedDate: git Last Modified
---
{% import "icons.njk" as icons %}

<article class="projects">
    <div class="header">
        <div>
            <h1>{{ title | safe }}</h1>
            <span class="meta muted">
                {% if updatedDate and createdDate != updatedDate %}
                    Updated: {{ updatedDate | postDate }},
                {% endif %}
                Created: {{ createdDate | postDate }}
            </span>
        </div>
        <div class="icons">
            {% if liveUrl %}
                <a class="icon-btn" href="{{ liveUrl }}" target="_blank" rel="noopener" aria-label="Launch {{ title }}">{{ icons.icon("play") }}</a>
            {% endif %}
            {% if githubRepo %}
                <a class="icon-btn" href="https://github.com/{{ githubRepo }}" target="_blank" rel="noopener" aria-label="View {{ title }} on GitHub">{{ icons.icon("github") }}</a>
            {% endif %}
        </div>
    </div>
    {{ content | safe }}
</article>
