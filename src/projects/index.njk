---
layout: base.njk
eleventyNavigation:
  key: Projects
  order: 2
---

<article class="projects">
  <h2>Projects</h2>
  <div class="cards">
    {%- for project in collections.projectsOrdered -%}
      {%- if project.url == "/projects/doodles/" -%}
        <div class="card doodles-card">
          <div>
            <h3>
              <a href="{{ project.url }}">{{ project.data.title }}</a>
            </h3>
            <p class="muted">Tiny single-file web toys reminiscent of the flash games of old.</p>
          </div>
          <div class="doodle-thumbs">
            {%- for doodle in collections.doodles | reverse -%}
              <img src="{{ doodle.data.image }}" alt="{{ doodle.data.title }}"/>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <div class="card">
          <div>
            <h3>
              <a href="{{ project.url }}">{{ project.data.title }}</a>
            </h3>
            <p class="muted">{{ project.data.description | safe }}</p>
          </div>
          <div>
            <img src="{{ project.data.image }}" alt="{{ project.data.title }}"/>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</article>
